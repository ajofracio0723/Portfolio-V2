# Resend (https://resend.com) — free: 3,000 emails/mo, 100/day
# Create an API key in the Resend dashboard, then paste it below.
# Restart `npm run dev` after changing env vars.
# Also add these same keys in Vercel → Project → Settings → Environment Variables.
RESEND_API_KEY=re_xxxxxxxx

# Where contact form messages are delivered (must match your Resend account email
# until you verify a custom domain).
# Must be the email on your Resend account until a domain is verified
CONTACT_TO_EMAIL=abejayofracio@gmail.com

# Default free sender (works before domain verification):
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
# After verifying your domain in Resend, switch to something like:
# RESEND_FROM_EMAIL=AJ Portfolio <hello@yourdomain.com>

# Optional public fallback shown in UI / mailto link
VITE_CONTACT_EMAIL=abejayofracio@gmail.com
